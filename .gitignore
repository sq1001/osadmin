# OSADMIN 后台管理系统 .gitignore

# 操作系统文件
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# 编辑器文件
.idea/
.vscode/
*.sublime-project
*.sublime-workspace
*.iml

# 依赖目录
node_modules/
bower_components/
vendor/

# 构建输出
dist/
build/
*.min.js
*.min.css

# 日志文件
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 临时文件
tmp/
temp/
.cache/

# 环境配置
.env
.env.local
.env.*.local

# 打包文件
*.zip
*.tar.gz
*.rar

# 测试覆盖率
coverage/
.nyc_output/

# 系统文件
*.bak
*.backup
*.old

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 配置文件（如果包含敏感信息）
# config/database.json
# config/secrets.json

# 上传文件目录
uploads/
upload/

# 缓存目录
.cache/
.temp/

# 其他
*.pid
*.seed
*.pid.lock
